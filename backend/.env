# SupportPilot AI — Environment Variables Template
# Copy to .env and fill in values

# Application
APP_ENV=development
APP_VERSION=0.1.0
SECRET_KEY=your-secret-key-here-change-in-production

# Database (SQLite for dev)
DATABASE_URL=sqlite+aiosqlite:///./data/supportpilot.db

# PostgreSQL for production
# DATABASE_URL=postgresql+asyncpg://supportpilot:supportpilot@db:5432/supportpilot

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_WEBHOOK_SECRET=whsec_xxx

# AI Provider (openai | anthropic | gemini | deepseek | openrouter | kimi | freekey)
AI_PROVIDER=openai
AI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
GEMINI_API_KEY=xxx
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
DEEPSEEK_API_KEY=xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_MODEL=openai/gpt-4o-mini

# Kimi (Moonshot)
KIMI_API_KEY=xxx
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=moonshot-v1-8k

# FreeKey (Custom OpenAI-compatible)
FREE_LLM_BASE_URL=http://localhost:1234/v1
FREE_LLM_API_KEY=xxx
FREE_LLM_MODEL=local-model

# File Storage
STORAGE_BACKEND=local
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=25

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_PRO=price_xxx

# Analytics
POSTHOG_API_KEY=phx_xxx
POSTHOG_HOST=https://app.posthog.com

# Monitoring
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS (JSON array format for pydantic-settings)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text
